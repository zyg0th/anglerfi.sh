{
    "meta": {
        "web": ["nmap", "nuclei", "httpx", "ffuf", "sqlmap", "gobuster", "wpscan", "caido", "feroxbuster"],
        "mobile": ["jadx", "adb", "apktool", "scrcpy", "android-studio", "uber-apk-signer", "apkeditor", "reflutter", "frida-tools", "pidcat", "hermes-dec", "palera1n"],
        "infra": ["nmap", "subfinder", "masscan", "amass", "netexec", "smbmap", "searchsploit", "python3-impacket", "hashcat", "john", "hydra"],
        "references": ["seclists", "payloadsallthethings", "internalallthethings", "hardwareallthethings", "mastg", "wstg", "gtfobins", "lolbas"],
        "osint": ["sherlock", "maigret", "holehe", "theharvester", "libimage-exiftool-perl", "gau", "waybackurls"],
        "dev": ["clang", "gcc", "neovim", "code"]
    },
    "apt": [
        {"name": "nmap", "version": "latest", "check": "command -v nmap"},
        {"name": "sqlmap", "version": "latest", "check": "command -v sqlmap"},
        {"name": "gobuster", "version": "latest", "check": "command -v gobuster"},
        {"name": "masscan", "version": "latest", "check": "command -v masscan"},
        {"name": "smbmap", "version": "latest", "check": "command -v smbmap"},
        {"name": "python3-impacket", "version": "latest", "check": "command -v impacket-secretsdump"},
        {"name": "wpscan", "version": "latest", "check": "command -v wpscan"},
        {"name": "jadx", "version": "latest", "check": "command -v jadx"},
        {"name": "apktool", "version": "latest", "check": "command -v apktool"},
        {"name": "adb", "version": "latest", "check": "command -v adb"},
        {"name": "scrcpy", "version": "latest", "check": "command -v scrcpy"},
        {"name": "hashcat", "version": "latest", "check": "command -v hashcat"},
        {"name": "john", "version": "latest", "check": "command -v john"},
        {"name": "hydra", "version": "latest", "check": "command -v hydra"},
        {"name": "libimage-exiftool-perl", "version": "latest", "check": "command -v exiftool"},
        {"name": "clang", "version": "latest", "check": "command -v clang"},
        {"name": "gcc", "version": "latest", "check": "command -v gcc"},
        {"name": "neovim", "version": "latest", "check": "command -v nvim"},
        {
            "name": "code",
            "version": "latest",
            "check": "command -v code",
            "pre_install": "wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg && printf 'Types: deb\\nURIs: https://packages.microsoft.com/repos/code\\nSuites: stable\\nComponents: main\\nArchitectures: amd64,arm64,armhf\\nSigned-By: /usr/share/keyrings/microsoft.gpg\\n' > /etc/apt/sources.list.d/vscode.sources && apt-get update"
        }
    ],
    "go": [
        {"name": "nuclei", "package": "github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest", "check": "command -v nuclei"},
        {"name": "httpx", "package": "github.com/projectdiscovery/httpx/cmd/httpx@latest", "check": "command -v httpx"},
        {"name": "ffuf", "package": "github.com/ffuf/ffuf/v2@latest", "check": "command -v ffuf"},
        {"name": "subfinder", "package": "github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest", "check": "command -v subfinder"},
        {"name": "amass", "package": "github.com/owasp-amass/amass/v4/...@master", "check": "command -v amass"},
        {"name": "netexec", "package": "github.com/Pennyw0rth/NetExec@latest", "check": "command -v netexec"},
        {"name": "gau", "package": "github.com/lc/gau/v2/cmd/gau@latest", "check": "command -v gau"},
        {"name": "waybackurls", "package": "github.com/tomnomnom/waybackurls@latest", "check": "command -v waybackurls"}
    ],
    "pipx": [
        {"name": "reflutter", "package": "reflutter==0.8.6", "check": "command -v reflutter"},
        {"name": "frida-tools", "package": "frida-tools==14.10.4", "check": "command -v frida"},
        {"name": "hermes-dec", "package": "hermes-dec", "check": "command -v hbc-disassembler"},
        {"name": "sherlock", "package": "sherlock-project", "check": "command -v sherlock"},
        {"name": "maigret", "package": "maigret", "check": "command -v maigret"},
        {"name": "holehe", "package": "holehe", "check": "command -v holehe"},
        {"name": "theharvester", "package": "git+https://github.com/laramies/theHarvester.git", "check": "command -v theHarvester"}
    ],
    "manual": [
        {
            "name": "caido",
            "check": "command -v caido",
            "install": "wget -O /tmp/caido.tar.gz https://caido.download/releases/v0.57.1/caido-desktop-v0.57.1-linux-x86_64.tar.gz",
            "artifact": "/tmp/caido.tar.gz",
            "hash": "ddddeaf172f618cd09b89e0f240aa00dd07627c708f237701a259a671701b1e9",
            "post_install": "mkdir -p /opt/caido && tar -xzf /tmp/caido.tar.gz -C /opt/caido --strip-components=1 && rm -f /tmp/caido.tar.gz && ln -sf /opt/caido/caido /usr/local/bin/caido && wget -q -O /opt/caido/icon.ico https://www.caido.io/favicon.ico && printf '[Desktop Entry]\\nName=Caido\\nComment=Web security auditing toolkit\\nExec=/opt/caido/caido %%U\\nIcon=/opt/caido/icon.ico\\nTerminal=false\\nType=Application\\nCategories=Network;Security;\\n' > /usr/share/applications/caido.desktop",
            "remove": "rm -rf /opt/caido && rm -f /usr/local/bin/caido /usr/share/applications/caido.desktop"
        },
        {
            "name": "android-studio",
            "check": "test -x /opt/android-studio/bin/studio.sh",
            "install": "wget -O /tmp/android-studio.tar.gz https://edgedl.me.gvt1.com/android/studio/ide-zips/2026.1.1.10/android-studio-quail1-patch2-linux.tar.gz",
            "artifact": "/tmp/android-studio.tar.gz",
            "hash": "fbd3f116d12caed724ea8da0d2cdae7e791170f79f2aa11273ea0f2d22a224dc",
            "post_install": "mkdir -p /opt/android-studio && tar -xzf /tmp/android-studio.tar.gz -C /opt/android-studio --strip-components=1 && rm -f /tmp/android-studio.tar.gz && ln -sf /opt/android-studio/bin/studio.sh /usr/local/bin/android-studio && printf '[Desktop Entry]\\nName=Android Studio\\nComment=Android IDE\\nExec=/opt/android-studio/bin/studio.sh\\nIcon=/opt/android-studio/bin/studio.png\\nTerminal=false\\nType=Application\\nCategories=Development;IDE;\\n' > /usr/share/applications/android-studio.desktop",
            "remove": "rm -rf /opt/android-studio && rm -f /usr/local/bin/android-studio /usr/share/applications/android-studio.desktop && rm -rf \"$HOME/.config/Google/AndroidStudio\"* \"$HOME/.cache/Google/AndroidStudio\"* \"$HOME/.local/share/Google/AndroidStudio\"*"
        },
        {
            "name": "uber-apk-signer",
            "check": "command -v uber-apk-signer",
            "install": "mkdir -p /opt/uber-apk-signer && wget -O /opt/uber-apk-signer/uber-apk-signer.jar https://github.com/patrickfav/uber-apk-signer/releases/download/v1.3.0/uber-apk-signer-1.3.0.jar",
            "artifact": "/opt/uber-apk-signer/uber-apk-signer.jar",
            "hash": "e1299fd6fcf4da527dd53735b56127e8ea922a321128123b9c32d619bba1d835",
            "post_install": "printf '#!/bin/sh\\nexec java -jar /opt/uber-apk-signer/uber-apk-signer.jar \"$@\"\\n' > /usr/local/bin/uber-apk-signer && chmod +x /usr/local/bin/uber-apk-signer",
            "remove": "rm -rf /opt/uber-apk-signer && rm -f /usr/local/bin/uber-apk-signer"
        },
        {
            "name": "apkeditor",
            "check": "command -v apkeditor",
            "install": "mkdir -p /opt/apkeditor && wget -O /opt/apkeditor/apkeditor.jar https://github.com/REAndroid/APKEditor/releases/download/V1.4.9/APKEditor-1.4.9.jar",
            "artifact": "/opt/apkeditor/apkeditor.jar",
            "hash": "a9cd40df818845456be6d696de6110c89edf4b0a0580cb83438ed6b25a366e67",
            "post_install": "printf '#!/bin/sh\\nexec java -jar /opt/apkeditor/apkeditor.jar \"$@\"\\n' > /usr/local/bin/apkeditor && chmod +x /usr/local/bin/apkeditor",
            "remove": "rm -rf /opt/apkeditor && rm -f /usr/local/bin/apkeditor"
        },
        {
            "name": "palera1n",
            "check": "command -v palera1n",
            "install": "wget -O /tmp/palera1n.deb https://github.com/palera1n/palera1n/releases/download/v2.3/palera1n_amd64.deb",
            "artifact": "/tmp/palera1n.deb",
            "hash": "7c34582989d8a008944976d57767bc0886bc74ebc346c95922072f36dfb77143",
            "post_install": "apt-get install -y /tmp/palera1n.deb && rm -f /tmp/palera1n.deb",
            "remove": "apt-get remove -y palera1n"
        },
        {
            "name": "feroxbuster",
            "check": "command -v feroxbuster",
            "install": "wget -O /tmp/feroxbuster.tar.gz https://github.com/epi052/feroxbuster/releases/download/v2.13.1/x86_64-linux-feroxbuster.tar.gz",
            "artifact": "/tmp/feroxbuster.tar.gz",
            "hash": "7985c00e6803b0f25d5e9139f7472279f3f4d891429627a5cedc629e53992d80",
            "post_install": "mkdir -p /opt/feroxbuster && tar -xzf /tmp/feroxbuster.tar.gz -C /opt/feroxbuster && rm -f /tmp/feroxbuster.tar.gz && chmod +x /opt/feroxbuster/feroxbuster && ln -sf /opt/feroxbuster/feroxbuster /usr/local/bin/feroxbuster",
            "remove": "rm -rf /opt/feroxbuster && rm -f /usr/local/bin/feroxbuster"
        },
        {
            "name": "gtfobins",
            "check": "test -f /usr/share/applications/gtfobins.desktop",
            "install": "wget -q -O /usr/share/pixmaps/gtfobins.png https://gtfobins.org/assets/logo.png && printf '[Desktop Entry]\\nName=GTFOBins\\nComment=Unix binaries local privesc/bypass cheatsheet\\nExec=xdg-open https://gtfobins.org/\\nIcon=/usr/share/pixmaps/gtfobins.png\\nTerminal=false\\nType=Application\\nCategories=Network;Security;\\n' > /usr/share/applications/gtfobins.desktop",
            "remove": "rm -f /usr/share/applications/gtfobins.desktop /usr/share/pixmaps/gtfobins.png"
        },
        {
            "name": "lolbas",
            "check": "test -f /usr/share/applications/lolbas.desktop",
            "install": "wget -q -O /usr/share/pixmaps/lolbas.png https://lolbas-project.github.io/assets/favicon.png && printf '[Desktop Entry]\\nName=LOLBAS\\nComment=Living Off The Land Binaries and Scripts\\nExec=xdg-open https://lolbas-project.github.io/\\nIcon=/usr/share/pixmaps/lolbas.png\\nTerminal=false\\nType=Application\\nCategories=Network;Security;\\n' > /usr/share/applications/lolbas.desktop",
            "remove": "rm -f /usr/share/applications/lolbas.desktop /usr/share/pixmaps/lolbas.png"
        }
    ],
    "git": [
        {
            "name": "pidcat",
            "check": "command -v pidcat",
            "repo": "https://github.com/JakeWharton/pidcat.git",
            "ref": "2.1.0",
            "post_clone": "chmod +x /opt/pidcat/pidcat.py && printf '#!/bin/sh\\nexec python3 /opt/pidcat/pidcat.py \"$@\"\\n' > /usr/local/bin/pidcat && chmod +x /usr/local/bin/pidcat",
            "remove": "rm -rf /opt/pidcat && rm -f /usr/local/bin/pidcat"
        },
        {
            "name": "searchsploit",
            "check": "command -v searchsploit",
            "repo": "https://gitlab.com/exploit-database/exploitdb.git",
            "ref": "main",
            "post_clone": "chmod +x /opt/searchsploit/searchsploit && ln -sf /opt/searchsploit/searchsploit /usr/local/bin/searchsploit",
            "remove": "rm -rf /opt/searchsploit && rm -f /usr/local/bin/searchsploit"
        },
        {
            "name": "seclists",
            "check": "test -d /opt/seclists",
            "repo": "https://github.com/danielmiessler/SecLists.git",
            "remove": "rm -rf /opt/seclists"
        },
        {
            "name": "payloadsallthethings",
            "check": "test -d /opt/payloadsallthethings",
            "repo": "https://github.com/swisskyrepo/PayloadsAllTheThings.git",
            "remove": "rm -rf /opt/payloadsallthethings"
        },
        {
            "name": "internalallthethings",
            "check": "test -d /opt/internalallthethings",
            "repo": "https://github.com/swisskyrepo/InternalAllTheThings.git",
            "remove": "rm -rf /opt/internalallthethings"
        },
        {
            "name": "hardwareallthethings",
            "check": "test -d /opt/hardwareallthethings",
            "repo": "https://github.com/swisskyrepo/HardwareAllTheThings.git",
            "remove": "rm -rf /opt/hardwareallthethings"
        },
        {
            "name": "mastg",
            "check": "test -d /opt/mastg",
            "repo": "https://github.com/OWASP/mastg.git",
            "remove": "rm -rf /opt/mastg"
        },
        {
            "name": "wstg",
            "check": "test -d /opt/wstg",
            "repo": "https://github.com/OWASP/wstg.git",
            "remove": "rm -rf /opt/wstg"
        }
    ]
}
